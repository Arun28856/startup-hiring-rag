# Copy this file to .env and fill in your values

# ─── Embeddings Service (Python / FastAPI) ───────────────────────────────────
# Groq API key — get a free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ─── Backend (NestJS) ────────────────────────────────────────────────────────
# URL of the embeddings service (set this on Railway to the internal service URL)
EMBEDDINGS_SERVICE_URL=http://localhost:8000

# Allowed CORS origin (set this to the Railway frontend URL in production)
CORS_ORIGIN=http://localhost:3000

# ─── Frontend (Next.js) ──────────────────────────────────────────────────────
# Public URL of the NestJS backend (set this to the Railway backend URL in production)
# NEXT_PUBLIC_ prefix makes this available in the browser
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001
